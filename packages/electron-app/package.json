{
  "name": "@wdym/electron-app",
  "version": "0.1.0",
  "description": "啥意思 — real-time conversation understanding tool",
  "author": "wdym",
  "private": true,
  "main": "./dist/main/index.js",
  "scripts": {
    "build": "tsc --build tsconfig.main.json && node build-renderer.mjs && cp src/renderer/index.html dist/renderer/index.html",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.main.tsbuildinfo tsconfig.renderer.tsbuildinfo",
    "start": "electron ./dist/main/index.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.wdym.app",
    "productName": "啥意思",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "src/renderer/assets/WDYM.icon/Assets/icon.png",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "啥意思 needs microphone access to capture and transcribe conversations in real time.",
        "NSScreenCaptureUsageDescription": "啥意思 needs screen recording access to capture system audio."
      }
    },
    "dmg": {
      "title": "啥意思",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ]
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@wdym/shared": "*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "motion": "^12.38.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "electron": "33.4.11",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3"
  }
}
